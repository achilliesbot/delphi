{
  "network": "base",
  "currency": "USDC",
  "services": {
    "signal-query": {
      "price": "0.002",
      "description": "Query DELPHI intelligence signals by type (security, market, ecosystem, api-health), severity, time range, or keyword. Returns structured, cryptographically signed signals for autonomous agents.",
      "methods": ["GET"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "description": "Signal type filter (e.g. market/yield, security/exploit)" },
            "severity": { "type": "string", "description": "Minimum severity: critical, high, medium, low, info" },
            "since": { "type": "string", "description": "ISO timestamp — only signals after this time" },
            "limit": { "type": "number", "description": "Max results (default 20, max 50)" }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "signals": { "type": "array", "description": "Array of signal objects with type, severity, title, data, confidence, signature" },
            "count": { "type": "number", "description": "Number of signals returned" }
          }
        }
      }
    },
    "latest-signals": {
      "price": "0.001",
      "description": "Get latest intelligence signals across all categories — market moves, security alerts, ecosystem changes, API health updates. Cheapest entry point to DELPHI.",
      "methods": ["GET"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "limit": { "type": "number", "description": "Number of signals (default 10, max 50)" }
          },
          "required": []
        },
        "output": {
          "type": "object",
          "properties": {
            "signals": { "type": "array", "description": "Latest signals array" },
            "count": { "type": "number" }
          }
        }
      }
    },
    "intelligence-report": {
      "price": "0.05",
      "description": "Deep intelligence report synthesized from recent DELPHI signals on any topic. Returns summary, key findings, severity distribution, and related signals.",
      "methods": ["GET"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "topic": { "type": "string", "description": "Topic to generate report on (required)" }
          },
          "required": ["topic"]
        },
        "output": {
          "type": "object",
          "properties": {
            "summary": { "type": "string", "description": "Synthesized intelligence summary" },
            "key_findings": { "type": "array", "description": "Top findings" },
            "signal_count": { "type": "number" }
          }
        }
      }
    },
    "noleak": {
      "price": "0.01",
      "description": "Execution integrity verification for AI agents. Checks for data leaks, unauthorized state changes, and integrity violations before any action. Returns clean/dirty status with threat list and confidence score.",
      "methods": ["POST"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "Agent identifier (required)" },
            "action": { "type": "string", "description": "Action to verify" },
            "context": { "type": "object", "description": "Additional context" }
          },
          "required": ["agent_id"]
        },
        "output": {
          "type": "object",
          "properties": {
            "clean": { "type": "boolean", "description": "Whether execution is clean" },
            "threats": { "type": "array", "description": "List of detected threats" },
            "confidence": { "type": "number", "description": "Confidence score 0-1" },
            "proof_hash": { "type": "string", "description": "Cryptographic proof hash" }
          }
        }
      }
    },
    "memguard": {
      "price": "0.01",
      "description": "Memory state verification — detects drift, corruption, and unauthorized modifications in agent memory. Compare current state against baseline snapshots.",
      "methods": ["POST"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "Agent identifier (required)" },
            "memory_hash": { "type": "string", "description": "Current memory state hash" },
            "expected_state": { "type": "string", "description": "Expected operational state" }
          },
          "required": ["agent_id"]
        },
        "output": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "description": "verified or failed" },
            "drift_detected": { "type": "boolean" },
            "corruption_detected": { "type": "boolean" },
            "unauthorized_mod": { "type": "boolean" },
            "integrity_score": { "type": "number", "description": "Score 0-1" }
          }
        }
      }
    },
    "riskoracle": {
      "price": "0.01",
      "description": "Pre-action risk scoring for AI agent decisions. Evaluates proposed actions by type, value, and context. Returns risk score, recommendation, and contributing factors.",
      "methods": ["POST"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "Agent identifier (required)" },
            "action": { "type": "string", "description": "Proposed action to evaluate" },
            "value": { "type": "number", "description": "Value involved in the action" },
            "context": { "type": "object", "description": "Additional context" }
          },
          "required": ["agent_id", "action"]
        },
        "output": {
          "type": "object",
          "properties": {
            "risk_score": { "type": "number", "description": "Risk score 0-1" },
            "recommendation": { "type": "string", "description": "proceed, caution, or block" },
            "factors": { "type": "array", "description": "Contributing risk factors" }
          }
        }
      }
    },
    "secureexec": {
      "price": "0.01",
      "description": "Tool execution security — validates tool calls before execution. Checks for injection, unauthorized access, and unsafe patterns.",
      "methods": ["POST"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "Agent identifier (required)" },
            "tool": { "type": "string", "description": "Tool being called" },
            "args": { "type": "array", "description": "Tool arguments" }
          },
          "required": ["agent_id", "tool"]
        },
        "output": {
          "type": "object",
          "properties": {
            "safe": { "type": "boolean", "description": "Whether execution is safe" },
            "threats": { "type": "array", "description": "Detected threats" },
            "execution_allowed": { "type": "boolean" }
          }
        }
      }
    },
    "flowcore": {
      "price": "0.02",
      "description": "Full orchestration pipeline — runs integrity check, memory verification, risk scoring, and execution security in a single call. Most comprehensive verification for agent actions.",
      "methods": ["POST"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "Agent identifier (required)" },
            "action": { "type": "string", "description": "Action to verify" },
            "value": { "type": "number", "description": "Value involved" },
            "memory_hash": { "type": "string", "description": "Current memory hash" }
          },
          "required": ["agent_id", "action"]
        },
        "output": {
          "type": "object",
          "properties": {
            "approved": { "type": "boolean", "description": "Whether action is approved" },
            "risk_score": { "type": "number" },
            "integrity": { "type": "string" },
            "pipeline_hash": { "type": "string", "description": "Pipeline verification hash" }
          }
        }
      }
    },
    "publish-signal": {
      "price": "0.005",
      "description": "Publish an intelligence signal to the DELPHI network. Publishers earn 70% of query fees when their signals are consumed by other agents.",
      "methods": ["POST"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "description": "Signal type (e.g. security/exploit, market/yield)" },
            "severity": { "type": "string", "description": "critical, high, medium, low, or info" },
            "title": { "type": "string", "description": "Human-readable signal title" },
            "data": { "type": "object", "description": "Structured signal data" },
            "confidence": { "type": "number", "description": "Confidence 0-1" }
          },
          "required": ["type", "title", "data"]
        },
        "output": {
          "type": "object",
          "properties": {
            "signal_id": { "type": "string" },
            "published": { "type": "boolean" },
            "expires_at": { "type": "string" }
          }
        }
      }
    }
  }
}
